<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Реестр КРСП</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <script>
        if (localStorage.getItem('auth') !== 'true') {
            window.location.href = 'login.html';
        }
    </script>
    <header>
        <a href="index.html">← На главную</a>
        <span>Реестр сообщений (КРСП) и проверок</span>
    </header>
    <main>
        <h2>РЕЕСТР ЗАРЕГИСТРИРОВАННЫХ ОБРАЩЕНИЙ</h2>
        <table id="registryTable">
            <thead>
                <tr>
                    <th>Номер</th>
                    <th>Дата</th>
                    <th>Тип</th>
                    <th>Заявитель</th>
                    <th>Суть</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </main>
    <script src="script.js"></script>
    <script>
        function loadRegistry() {
            const reports = JSON.parse(localStorage.getItem('reports') || '[]');
            const checks = JSON.parse(localStorage.getItem('checks') || '[]');
            const tbody = document.querySelector('#registryTable tbody');
            tbody.innerHTML = '';
            // Сначала рапорты
            reports.forEach((r, index) => {
                const row = tbody.insertRow();
                row.innerHTML = `
                    <td>${r.id}</td>
                    <td>${new Date(r.date).toLocaleString('ru-RU')}</td>
                    <td>Рапорт</td>
                    <td>${r.applicant}</td>
                    <td>${r.description.substring(0, 50)}...</td>
                    <td>
                        <select onchange="updateStatus('reports', ${index}, this.value)">
                            <option ${r.status === 'Зарегистрирован' ? 'selected' : ''}>Зарегистрирован</option>
                            <option ${r.status === 'В работе' ? 'selected' : ''}>В работе</option>
                            <option ${r.status === 'Завершён' ? 'selected' : ''}>Завершён</option>
                        </select>
                    </td>
                    <td><button onclick="deleteItem('reports', ${index})">Удалить</button></td>
                `;
            });
            // Затем запросы на проверку
            checks.forEach((c, index) => {
                const row = tbody.insertRow();
                row.innerHTML = `
                    <td>${c.id}</td>
                    <td>${new Date().toLocaleString('ru-RU')}</td>
                    <td>Запрос</td>
                    <td>${c.initiator}</td>
                    <td>${c.reason.substring(0, 50)}...</td>
                    <td>
                        <select onchange="updateCheckStatus(${index}, this.value)">
                            <option ${c.status === 'На рассмотрении' ? 'selected' : ''}>На рассмотрении</option>
                            <option ${c.status === 'Утверждён' ? 'selected' : ''}>Утверждён</option>
                            <option ${c.status === 'Отклонён' ? 'selected' : ''}>Отклонён</option>
                        </select>
                    </td>
                    <td><button onclick="deleteCheck(${index})">Удалить</button></td>
                `;
            });
        }
        window.onload = loadRegistry;
    </script>
</body>
</html>
